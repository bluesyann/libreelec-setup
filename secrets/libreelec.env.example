# Copy this file to /storage/.config/secrets/libreelec.env and fill values.
# This file must never be committed with real secrets.

# General
TZ=Europe/Paris
PUID=1000
PGID=1000

# JOAL
JOAL_UI_PATH_PREFIX=replace_me
JOAL_UI_SECRET_TOKEN=replace_me

# CUPS
CUPS_ADMIN=replace_me
CUPS_PASSWORD=replace_me

# MariaDB / weather scripts
MARIADB_ROOT_PASSWORD=replace_me
MARIADB_DATABASE=WeatherData
WEATHER_DB_USER=root
WEATHER_DB_PASSWORD=replace_me
WEATHER_STATION_IP=192.168.1.100
WEATHER_STATION_PORT=80

# Cloudflare tunnel
CLOUDFLARE_TUNNEL_TOKEN=replace_me

# Kodi web server credentials (used by installer docs/settings)
KODI_WEBSERVER_USER=replace_me
KODI_WEBSERVER_PASSWORD=replace_me
