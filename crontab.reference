* * * * * /storage/.config/scripts/feed_weather_db.sh
* * * * * /storage/.config/scripts/restart_containers_on_error.sh
* * * * * /storage/.config/scripts/watch_reboot_trigger.sh
0 6 * * * /storage/.kodi/addons/service.system.docker/bin/docker run --rm -v /media/Kodi_Storage/music:/dir flac2mp3 convert /dir >> /storage/.config/logs/flac-convert.log 2>&1
0 6 * * * /storage/.kodi/addons/service.system.docker/bin/docker run --rm -v /media/Kodi_Storage/downloads:/dir flac2mp3 split /dir >> /storage/.config/logs/album-split.log 2>&1
30 3 * * 1 /storage/.config/scripts/update_containers.sh
30 3 * * 2 /storage/.config/scripts/containers_backup.sh
30 3 * * 3 reboot